<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    android:label="@string/title_market"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="gparap.apps.classifieds.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_navigation_home_to_classifiedDetailsFragment"
            app:destination="@id/navigation_details" />
    </fragment>

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="gparap.apps.classifieds.ui.dashboard.DashboardFragment"
        android:label="@string/title_dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/navigation_notifications"
        android:name="gparap.apps.classifieds.ui.notifications.NotificationsFragment"
        android:label="@string/title_notifications"
        tools:layout="@layout/fragment_notifications" />
    <fragment
        android:id="@+id/navigation_market"
        android:name="gparap.apps.classifieds.ui.market.MarketFragment"
        android:label="@string/title_market"
        tools:layout="@layout/fragment_market" >
        <action
            android:id="@+id/action_navigation_market_to_animalsFragment"
            app:destination="@id/animalsFragment" />
        <action
            android:id="@+id/action_navigation_market_to_automobilesFragment"
            app:destination="@id/automobilesFragment" />
        <action
            android:id="@+id/action_navigation_market_to_clothingFragment"
            app:destination="@id/clothingFragment" />
        <action
            android:id="@+id/action_navigation_market_to_electronicsFragment"
            app:destination="@id/electronicsFragment" />
        <action
            android:id="@+id/action_navigation_market_to_employmentFragment"
            app:destination="@id/employmentFragment" />
        <action
            android:id="@+id/action_navigation_market_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_navigation_market_to_propertyFragment"
            app:destination="@id/propertyFragment" />
        <action
            android:id="@+id/action_navigation_market_to_servicesFragment"
            app:destination="@id/servicesFragment" />
        <action
            android:id="@+id/action_navigation_market_to_sportsFragment"
            app:destination="@id/sportsFragment" />
    </fragment>
    <fragment
        android:id="@+id/navigation_details"
        android:name="gparap.apps.classifieds.ui.details.DetailsFragment"
        android:label="fragment_details"
        tools:layout="@layout/fragment_details">
        <action
            android:id="@+id/action_classifiedDetailsFragment_to_navigation_home"
            app:destination="@id/navigation_home" />
        <argument
            android:name="argsClassifiedDescription"
            android:defaultValue=""
            app:argType="string" />
        <argument
            android:name="argsClassifiedPrice"
            android:defaultValue=""
            app:argType="string" />
        <argument
            android:name="argsClassifiedContact"
            android:defaultValue=""
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/animalsFragment"
        android:name="gparap.apps.classifieds.ui.market.categories.animals.AnimalsFragment"
        android:label="fragment_category_animals"
        tools:layout="@layout/fragment_category_animals" />
    <fragment
        android:id="@+id/automobilesFragment"
        android:name="gparap.apps.classifieds.ui.market.categories.automobiles.AutomobilesFragment"
        android:label="fragment_category_automobiles"
        tools:layout="@layout/fragment_category_automobiles" />
    <fragment
        android:id="@+id/clothingFragment"
        android:name="gparap.apps.classifieds.ui.market.categories.clothing.ClothingFragment"
        android:label="fragment_category_clothing"
        tools:layout="@layout/fragment_category_clothing" />
    <fragment
        android:id="@+id/electronicsFragment"
        android:name="gparap.apps.classifieds.ui.market.categories.electronics.ElectronicsFragment"
        android:label="fragment_category_electronics"
        tools:layout="@layout/fragment_category_electronics" />
    <fragment
        android:id="@+id/employmentFragment"
        android:name="gparap.apps.classifieds.ui.market.categories.employment.EmploymentFragment"
        android:label="fragment_category_employment"
        tools:layout="@layout/fragment_category_employment" />
    <fragment
        android:id="@+id/homeFragment"
        android:name="gparap.apps.classifieds.ui.market.categories.home.HomeFragment"
        android:label="fragment_category_home"
        tools:layout="@layout/fragment_category_home" />
    <fragment
        android:id="@+id/propertyFragment"
        android:name="gparap.apps.classifieds.ui.market.categories.property.PropertyFragment"
        android:label="fragment_category_property"
        tools:layout="@layout/fragment_category_property" />
    <fragment
        android:id="@+id/servicesFragment"
        android:name="gparap.apps.classifieds.ui.market.categories.services.ServicesFragment"
        android:label="fragment_category_services"
        tools:layout="@layout/fragment_category_services" />
    <fragment
        android:id="@+id/sportsFragment"
        android:name="gparap.apps.classifieds.ui.market.categories.sports.SportsFragment"
        android:label="fragment_category_sports"
        tools:layout="@layout/fragment_category_sports" />
</navigation>